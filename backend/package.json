{
  "name": "viet-phuc-backend",
  "version": "1.0.0",
  "description": "Backend API for Viet Phuc - Traditional Vietnamese Clothing E-commerce",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate:keys": "node generate-env-keys.js",
    "setup:env": "node generate-env-keys.js",
    "check:security": "node pre-commit-check.js",
    "validate:env": "node -e \"require('dotenv').config(); const required = ['MONGODB_URI', 'JWT_SECRET']; const missing = required.filter(k => !process.env[k]); if (missing.length) { console.error('Missing:', missing); process.exit(1); } else console.log('✅ All required env vars present');\"",
    "kill:port": "node kill-port.js",
    "restart": "node kill-port.js 3000 && npm start",
    "seed:superadmin": "node scripts/seed-super-admin.js",
    "sync:loyalty": "node scripts/sync-loyalty-from-orders.js",
    "rebuild:loyalty": "node scripts/rebuild-loyalty-from-orders.js"
  },
  "keywords": [
    "ecommerce",
    "traditional-clothing",
    "vietnamese"
  ],
  "author": "Group 13",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.15.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "axios": "^1.13.5",
    "form-data": "^4.0.5",
    "nodemon": "^3.0.1"
  }
}
