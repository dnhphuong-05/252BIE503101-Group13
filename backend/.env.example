# Environment
NODE_ENV=development

# Server
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/your_database_name

# Authentication & Security
JWT_SECRET=your-jwt-secret-key-here-min-32-characters

# Token Expiration Times
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session Secret (for cookie sessions)
SESSION_SECRET=your-session-secret-key-here-min-32-characters


# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret


# CORS Configuration
CORS_ORIGIN=http://localhost:4200,http://localhost:4201


# Cloudinary (Image Upload Service)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret


# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email From
EMAIL_FROM="Your Store Name <your-email@gmail.com>"

# Payment Gateway (Optional)
# VNPay
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:4200/payment/return

# Application Settings
# Pagination
DEFAULT_PAGE_SIZE=12
MAX_PAGE_SIZE=100

# Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_COUNT=10
